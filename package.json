{
  "name": "chrome-sidebar-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI-powered Chrome side panel built with React, TypeScript, Tailwind and Vite. Works with any OpenAI-compatible API.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.1",
    "@eslint/js": "^9.17.0",
    "@types/chrome": "^0.1.43",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "postcss": "^8.4.38",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.3.6",
    "vitest": "^4.1.9"
